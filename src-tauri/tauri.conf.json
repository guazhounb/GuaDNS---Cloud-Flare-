{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GuaDNS",
  "version": "1.0.0",
  "identifier": "com.guadns.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GuaDNS",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": []
  }
}
